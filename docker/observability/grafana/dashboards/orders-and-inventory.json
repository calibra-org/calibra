{
    "annotations": { "list": [] },
    "editable": true,
    "graphTooltip": 0,
    "id": null,
    "title": "Calibra — orders & inventory",
    "uid": "calibra-orders-inventory",
    "version": 1,
    "schemaVersion": 39,
    "timezone": "",
    "tags": ["calibra", "business", "orders", "inventory"],
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "30s",
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "Orders finalized / min",
            "description": "Live throughput of completed checkouts. Use the sparkline to spot sudden drops.",
            "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{ "color": "green", "value": null }]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
                "graphMode": "area"
            },
            "targets": [
                {
                    "expr": "sum(rate(calibra_orders_finalized_total[1m])) * 60",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 2,
            "type": "stat",
            "title": "Oversell attempts (1h)",
            "description": "Decrements that would have driven stock below zero with backorders=no. >= 1 fires the InventoryOversellAttempt alert immediately.",
            "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
                    }
                },
                "overrides": []
            },
            "options": { "reduceOptions": { "calcs": ["last"], "fields": "", "values": false } },
            "targets": [
                {
                    "expr": "sum(increase(calibra_inventory_oversell_attempts_total[1h])) or vector(0)",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "Inventory movements (stacked by kind)",
            "description": "Reservations / sales / restocks / releases per second. Healthy stores show a steady mix; a flat zero on 'sale' but rising 'reservation' means carts are being filled but checkouts aren't completing.",
            "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": { "mode": "palette-classic" },
                    "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30 }
                },
                "overrides": []
            },
            "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
            "targets": [
                {
                    "expr": "sum by (kind) (rate(calibra_inventory_movements_total[5m])) or vector(0)",
                    "legendFormat": "{{kind}}",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 4,
            "type": "barchart",
            "title": "Order transition mix (last 1h)",
            "description": "Total applied transitions over the last hour, grouped by (from → to). Reveals where orders are stuck (lots of draft→draft means abandoned carts; lots of pending→failed means payment issues).",
            "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
                "overrides": []
            },
            "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
            "targets": [
                {
                    "expr": "sum by (from, to) (increase(calibra_order_transitions_total{outcome=\"applied\"}[1h])) > 0",
                    "legendFormat": "{{from}} → {{to}}",
                    "instant": true,
                    "refId": "A"
                }
            ]
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "Checkout funnel — POST submit / finalize / verified",
            "description": "Three rates side by side: cart-submit requests, finalize events, and payment verifications. A widening gap between them quantifies where customers drop out.",
            "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
                "overrides": []
            },
            "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
            "targets": [
                {
                    "expr": "sum(rate(http_requests_total{route=\"/api/v1/checkout/submit\",method=\"POST\",status=\"200\"}[5m])) or vector(0)",
                    "legendFormat": "submit (200)",
                    "refId": "A"
                },
                {
                    "expr": "sum(rate(calibra_orders_finalized_total[5m])) or vector(0)",
                    "legendFormat": "finalize",
                    "refId": "B"
                },
                {
                    "expr": "sum(rate(calibra_payment_attempts_total{status=\"verified\"}[5m])) or vector(0)",
                    "legendFormat": "payment verified",
                    "refId": "C"
                }
            ]
        },
        {
            "id": 6,
            "type": "timeseries",
            "title": "Inventory deltas: sale vs return",
            "description": "Net stock outflow. Returns ticking up faster than sales means refund volume is spiking.",
            "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
                "overrides": []
            },
            "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
            "targets": [
                {
                    "expr": "rate(calibra_inventory_movements_total{kind=\"sale\"}[5m]) or vector(0)",
                    "legendFormat": "sale",
                    "refId": "A"
                },
                {
                    "expr": "rate(calibra_inventory_movements_total{kind=\"return\"}[5m]) or vector(0)",
                    "legendFormat": "return",
                    "refId": "B"
                }
            ]
        }
    ]
}
