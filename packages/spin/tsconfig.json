{
    "extends": "@calibra/typescript-config/internal-package.json",
    "compilerOptions": {
        "lib": ["ESNext", "dom", "dom.iterable"],
        "types": ["node", "react", "react-dom"],
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "rootDir": ".",
        "noEmit": true
    },
    "include": ["src", "test", "tsdown.config.ts"],
    "exclude": ["node_modules", "dist", ".cache"]
}
