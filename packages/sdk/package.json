{
    "name": "@calibra/sdk",
    "version": "0.0.0",
    "private": true,
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "source": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest --run --passWithNoTests",
        "test:coverage": "vitest --coverage --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit --emitDeclarationOnly false"
    },
    "devDependencies": {
        "@calibra/typescript-config": "workspace:*",
        "@types/node": "catalog:",
        "msw": "catalog:",
        "tsdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
