        },
        "./i18n": {
            "types": "./src/i18n.ts",
            "import": "./src/i18n.ts"
        },
        "./digits": {
            "types": "./src/digits.ts",
            "import": "./src/digits.ts"
        },
        "./jalali": {
            "types": "./src/jalali.ts",
