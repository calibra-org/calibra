{
    "name": "@calibra/panel-kit",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./icons": {
            "types": "./src/icons/index.ts",
            "import": "./src/icons/index.ts"
        },
        "./table": {
            "types": "./src/table.tsx",
            "import": "./src/table.tsx"
        },
        "./*.demo": {
            "types": "./src/*.demo.tsx",
            "import": "./src/*.demo.tsx"
        },
        "./*": {
            "types": "./src/*/index.tsx",
            "import": "./src/*/index.tsx"
        }
    },
    "scripts": {
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@base-ui/react": "catalog:",
        "@calibra/shared": "workspace:*",
        "@radix-ui/react-slot": "catalog:",
        "class-variance-authority": "catalog:",
        "lucide-react": "catalog:",
        "next-intl": "catalog:",
        "radix-ui": "catalog:",
        "tailwind-variants": "catalog:"
    },
    "peerDependencies": {
        "react": "catalog:",
        "react-dom": "catalog:"
    },
    "devDependencies": {
        "@calibra/typescript-config": "workspace:*",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "typescript": "catalog:"
    }
}
