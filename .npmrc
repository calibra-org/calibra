auto-install-peers=true
ignore-workspace-root-check=true

# size-limit discovers @size-limit/* plugins via Node's module resolution at runtime; pnpm's
# default isolation hides them inside the .pnpm store where size-limit can't find them. Hoist
# them to the top-level node_modules so the CLI resolves cleanly. See
# packages/kit/.size-limit.cjs.
public-hoist-pattern[]=@size-limit/*