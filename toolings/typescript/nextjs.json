{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Next.js",
    "extends": "./base.json",
    "compilerOptions": {
        "lib": ["ESNext", "dom", "dom.iterable"],
        "jsx": "preserve",
        "plugins": [{ "name": "next" }],
        "module": "esnext"
    },
    "include": [".", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
