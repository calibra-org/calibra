# Copy to .env and adjust. Never commit .env.

TZ=UTC
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
APP_NAME=calibra-api
LOG_LEVEL=info

# Generate with `node ace generate:key`. Rotating this invalidates every signed cookie / URL.
APP_KEY=replace-me-with-a-32-char-random-string

# Matches the docker-compose.yml defaults.
# Multi-tenancy uses two Postgres roles (see config/database.ts):
#   DB_USER         runtime app role (calibra_app, NOBYPASSRLS) — RLS always enforced
#   DB_ADMIN_USER   migrations/seeders/worker (calibra_admin, BYPASSRLS)
#   DB_SUPERUSER_*  only used by `node ace db:bootstrap-roles` to CREATE the roles
DB_HOST=localhost
DB_PORT=5432
DB_USER=calibra_app
DB_PASSWORD=calibra_app
DB_DATABASE=calibra
DB_ADMIN_USER=calibra_admin
DB_ADMIN_PASSWORD=calibra_admin
DB_SUPERUSER_USER=calibra
DB_SUPERUSER_PASSWORD=calibra

# Phone-OTP SMS sender. `log` writes the code to Pino (dev/test, no dependency); `provider`
# slots an Iranian gateway over fetch once approved. SMS_FROM is the config-level sender fallback.
SMS_DRIVER=log
# SMS_FROM=Calibra

# Comma-separated. Add the admin panel here once it's deployed.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Mail / SMTP. Local dev points at Mailpit (scripts/mailpit-compose.yml).
MAIL_FROM_ADDRESS=ops@calibra.local
MAIL_FROM_NAME=Calibra
MAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=11025
# SMTP_USERNAME=
# SMTP_PASSWORD=
MAILPIT_WEB_URL=http://localhost:18025

# Redis (shared dev container via `scripts/dev-ui-compose.yml` on :16379). Powers
# Transmit's redis transport (cross-process SSE) and any future cache / limiter / lock store.
# Per-spin keyspace isolation lives in `config/redis.ts` via `keyPrefix: ${APP_NAME}:`.
REDIS_HOST=localhost
REDIS_PORT=16379
# REDIS_PASSWORD=

# Transmit transport. `redis` bridges SSE broadcasts across the api ↔ queue worker
# processes (required when QUEUE_DRIVER=database). `none` keeps it single-process.
TRANSMIT_TRANSPORT=redis

# Background-job queue.
#  - `database`: dev + prod default. Jobs persisted in Postgres; `node ace queue:work`
#    picks them up. Transmit's redis transport bridges worker broadcasts back to the api.
#  - `sync`: tests only (.env.test). Runs jobs inline in the dispatcher.
QUEUE_DRIVER=database

# Rate limiter store. `redis` in dev/prod; `memory` in tests.
LIMITER_STORE=redis

# Default cache store. `redis` selects the multi-tier (L1 memory + L2 Redis + bus) store in
# `config/cache.ts`; `memory` selects the single-tier in-process store and is what tests use.
CACHE_DRIVER=redis
