{
    "name": "@calibra/api",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "imports": {
        "#abilities/*": "./app/abilities/*.js",
        "#controllers/*": "./app/controllers/*.js",
        "#contracts/*": "./app/contracts/*.js",
        "#events/*": "./app/events/*.js",
        "#listeners/*": "./app/listeners/*.js",
        "#commands/*": "./commands/*.js",
        "#exceptions/*": "./app/exceptions/*.js",
        "#jobs/*": "./app/jobs/*.js",
        "#mails/*": "./app/mails/*.js",
        "#models/*": "./app/models/*.js",
        "#services/*": "./app/services/*.js",
        "#middleware/*": "./app/middleware/*.js",
        "#enums/*": "./app/enums/*.js",
        "#lib/*": "./app/lib/*.js",
        "#table_views/*": "./app/table_views/*.js",
        "#validators/*": "./app/validators/*.js",
        "#transformers/*": "./app/transformers/*.js",
        "#providers/*": "./providers/*.js",
        "#database/*": "./database/*.js",
        "#factories/*": "./database/factories/*.js",
        "#start/*": "./start/*.js",
        "#tests/*": "./tests/*.js",
        "#config/*": "./config/*.js",
        "#generated/*": "./.adonisjs/server/*.js"
    },
    "scripts": {
        "start": "node bin/server.js",
        "build": "node ace build",
        "dev": "node ace serve --hmr",
        "pretest": "pnpm --filter @calibra/api-docs run build:test-spec",
        "test": "node ace test",
        "check:api-docs": "node ace check:api-docs",
        "typecheck": "tsc --noEmit",
        "migration:run": "node ace migration:run",
        "migration:rollback": "node ace migration:rollback",
        "db:seed": "node ace db:seed",
        "up": "docker compose up -d",
        "down": "docker compose down",
        "logs": "docker compose logs -f api",
        "reset": "docker compose down -v && docker compose up -d"
    },
    "dependencies": {
        "@adonisjs/auth": "^10.1.0",
        "@adonisjs/bouncer": "^4.0.0",
        "@adonisjs/cache": "^2.1.0",
        "@adonisjs/core": "^7.3.2",
        "@adonisjs/cors": "^3.0.0",
        "@adonisjs/drive": "^4.0.0",
        "@adonisjs/i18n": "^3.0.0",
        "@adonisjs/limiter": "^3.0.1",
        "@adonisjs/lock": "^2.1.0",
        "@adonisjs/lucid": "^22.4.2",
        "@adonisjs/mail": "^10.2.1",
        "@adonisjs/otel": "^1.2.3",
        "@adonisjs/queue": "^0.6.1",
        "@adonisjs/redis": "^10.0.0",
        "@adonisjs/shield": "^9.0.0",
        "@adonisjs/transmit": "^3.0.1",
        "@faker-js/faker": "^10.4.0",
        "@mohammadxali/jalaali-js": "2.0.0-preview.0",
        "@sentry/node": "^10.53.1",
        "@vinejs/vine": "^4.4.0",
        "luxon": "^3.5.0",
        "meilisearch": "^0.58.0",
        "papaparse": "^5.5.3",
        "pg": "^8.13.1",
        "reflect-metadata": "^0.2.2",
        "sanitize-html": "^2.17.4",
        "sharp": "0.34.5",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@adonisjs/assembler": "^8.4.0",
        "@adonisjs/tsconfig": "^2.0.0",
        "@japa/api-client": "^3.2.1",
        "@japa/assert": "^4.2.0",
        "@japa/openapi-assertions": "^0.1.2",
        "@japa/plugin-adonisjs": "^5.2.0",
        "@japa/runner": "^5.3.0",
        "@poppinss/ts-exec": "^1.4.4",
        "@types/luxon": "^3.4.2",
        "@types/node": "catalog:",
        "@types/papaparse": "^5.3.16",
        "@types/sanitize-html": "^2.16.0",
        "hot-hook": "^1.0.0",
        "pino-pretty": "^13.1.3",
        "typescript": "~5.9",
        "youch": "^4.1.1"
    },
    "hotHook": {
        "boundaries": [
            "./app/controllers/**/*.ts",
            "./app/middleware/*.ts"
        ]
    }
}
