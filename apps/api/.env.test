NODE_ENV=test
PORT=3334
HOST=0.0.0.0
APP_NAME=calibra-api
LOG_LEVEL=warn

APP_KEY=test-only-key-not-used-for-real-secrets

DB_HOST=localhost
DB_PORT=5432
DB_USER=calibra
DB_PASSWORD=calibra
DB_DATABASE=calibra_test

ALLOWED_ORIGINS=http://localhost:3000

# Mail / SMTP — tests don't actually send; sendLater is gated by MAIL_NOTIFICATIONS_ENABLED=false.
MAIL_FROM_ADDRESS=ops@calibra.local
MAIL_FROM_NAME=Calibra
MAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=11025

# Run job dispatches inline so functional tests stay deterministic — no worker process needed.
QUEUE_DRIVER=sync

# Redis env vars are required by `start/env.ts` but never reached at test time — the queue
# driver is `sync` (no Transmit broadcast cross-process) and no test exercises the cache /
# limiter / lock Redis path yet. Localhost defaults keep `Env.create()` happy.
REDIS_HOST=localhost
REDIS_PORT=6379
# Tests run in-process; no broadcast needs to cross to a worker.
TRANSMIT_TRANSPORT=none

LIMITER_STORE=memory
CACHE_DRIVER=memory
