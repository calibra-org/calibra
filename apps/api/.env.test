NODE_ENV=test
PORT=3334
HOST=0.0.0.0
APP_NAME=calibra-api
LOG_LEVEL=warn

APP_KEY=test-only-key-not-used-for-real-secrets

DB_HOST=localhost
DB_PORT=5432
DB_USER=calibra
DB_PASSWORD=calibra
DB_DATABASE=calibra_test

ALLOWED_ORIGINS=http://localhost:3000

# Mail / SMTP — tests don't actually send; sendLater is gated by MAIL_NOTIFICATIONS_ENABLED=false.
MAIL_FROM_ADDRESS=ops@calibra.local
MAIL_FROM_NAME=Calibra
MAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=11025

# Run job dispatches inline so functional tests stay deterministic — no worker process needed.
QUEUE_DRIVER=sync
