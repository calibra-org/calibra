# Copy to .env.local and adjust. Never commit .env.local.

# Where the AdonisJS API is reachable.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333

# Public URL the console is served from.
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Default UI locale (one of @calibra/shared/i18n; "fa" or "en"). Falls back to "fa".
NEXT_PUBLIC_DEFAULT_LOCALE=fa

# Embedded Grafana base URL for the per-tenant ops panel (Phase 6 supplies the dashboard + var-tenant).
NEXT_PUBLIC_GRAFANA_BASE=
NEXT_PUBLIC_GRAFANA_TENANT_DASHBOARD_UID=
