.env
.env.local

# Anything that lands inside the bind-mounted plugins dir from auto-installs
# (the mu-bootstrap script downloads WooCommerce/Polylang into the *container*
# volume, but if a developer mounts the path differently this keeps it clean).
wp-content/plugins/*/
!wp-content/plugins/.gitkeep

# Uploads land in the wp_data named volume; nothing should appear here, but
# guard against accidental host paths being written.
wp-content/uploads/
