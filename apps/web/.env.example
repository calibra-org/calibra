# Copy to .env.local and adjust. Never commit .env.local.

# WordPress origin used by the SDK (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Public URL the storefront is served from. Used for canonical/og metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Allowed origins forwarded into the CMS for CORS allowlisting (see apps/cms theme functions.php).
ALLOWED_ORIGINS=http://localhost:3000
