# Copy to .env.local and adjust. Never commit .env.local.

# WordPress origin used by the SDK (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Public URL the storefront is served from. Used for canonical/og metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default UI locale. Must be one of the locales in @calibra/shared/i18n (currently "fa" or "en").
# Falls back to "fa" if unset or invalid.
NEXT_PUBLIC_DEFAULT_LOCALE=fa

# Allowed origins forwarded into the CMS for CORS allowlisting (see apps/cms theme functions.php).
ALLOWED_ORIGINS=http://localhost:3000
